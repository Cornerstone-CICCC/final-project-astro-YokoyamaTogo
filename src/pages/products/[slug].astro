---
import type { GetStaticPaths } from "astro"
import Layout from "../../layouts/Layout.astro"
import type { Product } from "../../models/Product"
import { catalog } from "../../models/ProductCatalog"

export const getStaticPaths: GetStaticPaths = () => {
  return catalog.getAllProducts().map((product: Product) => ({
    params: { slug: product.getSlug() },
    props: { product },
  }))
}

interface Props {
  product: Product
}

const { product }: Props = Astro.props
const stockClass = product.isInStock()
  ? "mt-3 text-sm font-medium text-emerald-700"
  : "mt-3 text-sm font-medium text-red-700"
const stockLabel = product.isInStock() ? "In stock" : "Out of stock"
---

<Layout title={`${product.title} | Product Details`}>
  <a class="text-sm font-medium text-amber-700 hover:text-amber-800" href="/">Back to products</a>

  <section class="mt-6 grid gap-8 lg:grid-cols-2">
    <div class="flex aspect-[4/3] items-center justify-center rounded-lg bg-stone-100">
      <span class="text-sm font-medium uppercase tracking-wide text-stone-500">{product.category}</span>
    </div>

    <div class="flex flex-col justify-center">
      <p class="text-sm font-medium capitalize text-stone-500">{product.category}</p>
      <h1 class="mt-2 text-4xl font-bold tracking-tight text-stone-950">{product.title}</h1>
      <p class="mt-4 text-2xl font-semibold text-amber-700">{product.getFormattedPrice()}</p>
      <p class={stockClass}>{stockLabel}</p>
      <p class="mt-6 max-w-prose text-lg leading-8 text-stone-700">{product.description}</p>
    </div>
  </section>
</Layout>
